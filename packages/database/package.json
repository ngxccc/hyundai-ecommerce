{
  "name": "@nhatnang/database",
  "version": "0.0.0",
  "description": "Database configuration and migrations",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./env": "./src/env.ts",
    "./schemas": "./src/schemas/index.ts",
    "./services": "./src/services/index.ts",
    "./validators": "./src/validators/index.ts",
    "./dtos": "./src/dtos/index.ts",
    "./auth": "./src/auth.ts",
    "./auth-client": "./src/auth-client.ts"
  },
  "scripts": {
    "check-types": "tsc --noEmit",
    "db:baseline": "doppler run -c dev -- bun scripts/baseline.ts && doppler run -c prd -- bun scripts/baseline.ts --inject-only && doppler run -c stg -- bun scripts/baseline.ts --inject-only",
    "db:generate": "doppler run -- drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "doppler run -- drizzle-kit migrate --config drizzle.config.ts",
    "db:migrate:prod": "doppler run -c prd -- drizzle-kit migrate --config drizzle.config.ts",
    "db:migrate:test": "doppler run -c stg -- drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "doppler run -- drizzle-kit push --config drizzle.config.ts",
    "db:push:prod": "doppler run -c prd -- drizzle-kit push --config drizzle.config.ts",
    "db:push:test": "doppler run -c stg -- drizzle-kit push --config drizzle.config.ts",
    "db:seed": "doppler run -c dev -- bun scripts/seed.ts",
    "db:seed:test": "doppler run -c stg -- bun scripts/seed.ts",
    "db:studio": "doppler run -- drizzle-kit studio --config drizzle.config.ts",
    "docs:gen": "bun run scripts/generate-docs.ts",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location .eslintcache",
    "test": "doppler run -- bun test src/"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.18",
    "@neondatabase/serverless": "^1.1.0",
    "@paralleldrive/cuid2": "^3.3.0",
    "@t3-oss/env-core": "^0.13.11",
    "@nhatnang/ui": "workspace:*",
    "better-auth": "^1.6.18",
    "drizzle-orm": "v1.0.0-rc.3",
    "postgres": "^3.4.9",
    "resend": "^6.12.3",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nhatnang/eslint-config": "workspace:*",
    "@nhatnang/shared": "workspace:*",
    "@nhatnang/typescript-config": "workspace:*",
    "@types/bun": "^1",
    "@types/node": "^25",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "v1.0.0-rc.3"
  }
}
