{
  "name": "@nhatnang/database",
  "version": "0.0.0",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "description": "Database configuration and migrations",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./auth": "./src/auth.ts",
    "./queries": "./src/queries/index.ts"
  },
  "scripts": {
    "db:push": "bunx drizzle-kit push --config drizzle.config.ts",
    "db:generate": "bunx drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bunx drizzle-kit migrate --config drizzle.config.ts",
    "db:studio": "bunx drizzle-kit studio --config drizzle.config.ts",
    "db:seed": "bun src/seed.ts",
    "docs:gen": "bun run scripts/generate-docs.ts",
    "lint": "eslint . --cache --cache-strategy content --cache-location .eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-strategy content --cache-location .eslintcache"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.9",
    "@neondatabase/serverless": "^1.0.2",
    "@paralleldrive/cuid2": "^3.3.0",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^1.0.0-rc.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nhatnang/eslint-config": "workspace:*",
    "@nhatnang/shared": "workspace:*",
    "@nhatnang/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^1.0.0-rc.1",
    "eslint": "^10"
  }
}
