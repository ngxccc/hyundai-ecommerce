{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": ["NEXT_PUBLIC_API_URL", "DATABASE_URL"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "!.next/dev/**",
        "!.next/types/**"
      ],
      "cache": true
    },
    "check-types": {
      "dependsOn": ["^check-types"],
      "cache": true
    },
    "lint": {
      "dependsOn": ["^lint"],
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "eslint.config.*",
        "**/*.{js,jsx,ts,tsx}",
        "packages/eslint-config/**"
      ]
    },
    "dev": {
      "persistent": true,
      "cache": false
    }
  },
  "globalDependencies": [
    "tsconfig.json",
    "package.json",
    "turbo.json",
    ".prettierrc",
    ".prettierignore",
    "packages/eslint-config/**",
    "packages/typescript-config/**"
  ]
}
