{
  "indent": "  ",

  "sortFirst": [
    "name",
    "version",
    "description",
    "private",
    "type",
    "exports",
    "packageManager",
    "workspaces",
    "scripts",
    "dependencies",
    "devDependencies",
    "peerDependencies"
  ],

  "sortAz": [
    "scripts",
    "dependencies",
    "devDependencies",
    "peerDependencies"
  ],

  "semverGroups": [
    {
      "range": "^",
      "dependencies": ["**"],
      "packages": ["**"]
    }
  ],
  "versionGroups": [
    {
      "dependencies": ["next"],
      "packages": ["**"],
      "isIgnored": true
    },
    {
      "dependencies": ["@nhatnang/**"],
      "packages": ["**"],
      "isIgnored": true
    }
  ]
}
