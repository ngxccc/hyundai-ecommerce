{
  "extends": "@nhatnang/typescript-config/next",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": ["./src/*"],
      "#/*": ["./public/*"],
    },
    "types": ["bun", "node"],
  },
  "include": [
    "next-env.d.ts",
    "**/*.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "app/.well-known/**/*.ts",
    "**/*.mts",
    "**/*.js",
    "**/*.mjs",
  ],
  "exclude": ["node_modules"],
}
