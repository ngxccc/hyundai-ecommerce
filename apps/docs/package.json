{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "check-types": "fumadocs-mdx && next typegen && tsc --noEmit",
    "dev": "next dev -p 3002",
    "lint": "eslint . --cache --cache-location .eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location .eslintcache",
    "postinstall": "fumadocs-mdx",
    "start": "next start -p 3002"
  },
  "dependencies": {
    "fumadocs-core": "^16.10.4",
    "fumadocs-mdx": "^15.0.11",
    "fumadocs-ui": "^16.10.4",
    "lucide-react": "^1.21.0",
    "next": "^16.2.9",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@nhatnang/eslint-config": "workspace:*",
    "@nhatnang/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.1"
  }
}
