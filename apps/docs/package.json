{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev -p 3001",
    "start": "next start -p 3001",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "lint": "eslint . --cache --cache-strategy content --cache-location .eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-strategy content --cache-location .eslintcache"
  },
  "dependencies": {
    "fumadocs-core": "16.8.7",
    "fumadocs-mdx": "14.3.2",
    "fumadocs-ui": "^16.8.7",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@nhatnang/eslint-config": "workspace:*",
    "@nhatnang/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  }
}
