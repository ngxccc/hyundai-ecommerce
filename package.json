{
  "name": "hyundai-ecommerce",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "doppler run -- turbo run build",
    "check-types": "turbo run check-types",
    "clean": "bunx rimraf '**/node_modules' '**/.next' '**/.turbo'",
    "clean:hard": "bunx rimraf '**/node_modules' '**/.next' '**/.turbo' 'bun.lock' && bun install",
    "deps:fix": "syncpack fix",
    "deps:lint": "syncpack list",
    "dev": "doppler run -- turbo run dev",
    "dev:storefront": "doppler run -- turbo run dev --filter=storefront",
    "format:pkg": "syncpack format",
    "format:pkg:check": "syncpack format --check",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@types/bun": "^1",
    "@types/node": "^25",
    "eslint": "^9",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "syncpack": "^15.3.1",
    "turbo": "^2.9.17",
    "typescript": "^6"
  }
}
