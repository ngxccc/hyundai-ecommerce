{
  "name": "hyundai-ecommerce",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.6",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "doppler run -- turbo run dev",
    "dev:storefront": "doppler run -- turbo run dev --filter=storefront",
    "build": "doppler run -- turbo run build",
    "lint": "turbo run lint"
  },
  "dependencies": {
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1",
    "@types/node": "^25",
    "@types/uuid": "^11",
    "eslint": "^9",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.15",
    "typescript": "^6"
  }
}
