{
  "claude-compatibility-hooks": {
    "enabled": true,
    "PreToolUse": [
      {
        "matcher": "write_to_file",
        "hooks": [
          {
            "type": "command",
            "command": "node ./ag-adapter.cjs PreToolUse .claude/hooks/descriptive-name.cjs"
          }
        ]
      },
      {
        "matcher": "run_command|find_by_name|grep_search|view_file|read_url_content|replace_file_content|multi_replace_file_content|write_to_file",
        "hooks": [
          {
            "type": "command",
            "command": "node ./ag-adapter.cjs PreToolUse .claude/hooks/scout-block.cjs"
          },
          {
            "type": "command",
            "command": "node ./ag-adapter.cjs PreToolUse .claude/hooks/privacy-block.cjs"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "replace_file_content|write_to_file|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "node ./ag-adapter.cjs PostToolUse .claude/hooks/session-state.cjs"
          },
          {
            "type": "command",
            "command": "node ./ag-adapter.cjs PostToolUse .claude/hooks/post-edit-simplify-reminder.cjs"
          }
        ]
      }
    ],
    "PreInvocation": [
      {
        "type": "command",
        "command": "node ./ag-adapter.cjs PreInvocation .claude/hooks/session-init.cjs"
      },
      {
        "type": "command",
        "command": "node ./ag-adapter.cjs PreInvocation .claude/hooks/subagent-init.cjs"
      }
    ]
  }
}
